# The agents' brain. LLM_PROVIDER picks it:
#   auto (default) — OpenRouter if keyed, else local Ollama if reachable, else mock
#   openrouter | ollama | mock — force one
LLM_PROVIDER=auto

# Option A: OpenRouter (cloud)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx
OPENROUTER_MODEL=openai/gpt-4o-mini

# Option B: Ollama (local-first, free, private — sayhai style)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b

# With neither configured the portal runs in demo mode: agents answer
# from canned quips (still emotion-tagged, so the presence layer reacts).

# Admin — protects /admin, /api/admin/*, the admin SSE stream, and
# direct event injection (POST /api/agent/events). Unset = locked out.
ADMIN_PASSWORD=your-admin-password

# Webhooks — external systems pushing events onto the page.
# Generic endpoint (POST /api/webhook/generic, header x-webhook-secret):
WEBHOOK_SECRET_GENERIC=your-generic-webhook-secret
# Named source endpoint (POST /api/webhook/openclaw):
WEBHOOK_SECRET_OPENCLAW=your-openclaw-webhook-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
