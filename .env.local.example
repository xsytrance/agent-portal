# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_ALLOWED_MODELS=openai/gpt-4o-mini,openai/gpt-4o,anthropic/claude-3.5-sonnet,google/gemini-1.5-flash
OPENROUTER_EMERGENCY_DISABLED=false

# Admin
ADMIN_PASSWORD=your-admin-password
ADMIN_EMAILS=admin@example.com
ADMIN_BASIC_AUTH_ENABLED=true
NEXTAUTH_SECRET=replace-with-at-least-16-random-characters
NEXTAUTH_URL=http://localhost:3000

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_portal

# Stripe sandbox
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
STRIPE_PRICE_5=
STRIPE_PRICE_10=
STRIPE_PRICE_20=
STRIPE_PRICE_50=

# Commercial safety caps
DAILY_SPEND_CAP_MICROCREDITS=10000000
GLOBAL_DAILY_SPEND_CAP_MICROCREDITS=100000000
MAX_PROMPT_CHARS=12000
